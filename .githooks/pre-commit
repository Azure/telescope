#!/bin/bash
# Pre-commit hook: regenerate all pipeline.yaml files from pipeline.k files under kcl/
# Always regenerates to catch changes in shared helpers, dependencies, etc.

if ! command -v kcl &> /dev/null; then
  echo "Error: kcl CLI not found. Install it: https://kcl-lang.io/docs/user_docs/getting-started/install"
  exit 1
fi

FAILED=0
REPO=$(pwd)
PIPELINE_FILE="pipeline.k"
for K_FILE in $(find kcl/ -name "$PIPELINE_FILE"); do
  DIR=$(dirname "$K_FILE")
  echo $DIR
  cd $DIR
  YAML_FILE="pipeline.yaml"

  echo "Generating $YAML_FILE from $K_FILE..."
  if kcl run "$PIPELINE_FILE" -S output -o "$YAML_FILE" 2>&1; then
    git add "$YAML_FILE"
  else
    echo "Error: kcl run failed for $K_FILE"
    FAILED=1
  fi
  cd $REPO
done

if [ "$FAILED" -ne 0 ]; then
  echo "Pre-commit hook failed: KCL compilation errors. Fix them before committing."
  exit 1
fi
